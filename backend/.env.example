# Environment Variables Template
# Copy this to .env and fill in your values

# ─────────────────────────────────────────────────────────────────────────────
# API CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ENV=development
DEBUG=True

# ─────────────────────────────────────────────────────────────────────────────
# PATH CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
LOGS_DIR=logs

# ─────────────────────────────────────────────────────────────────────────────
# MODAL CONFIGURATION (Optional - for GPU acceleration)
# ─────────────────────────────────────────────────────────────────────────────
# Set to True to use Modal instead of local model
USE_MODAL=True
# Get your token with: modal token new
MODAL_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# CORS CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ─────────────────────────────────────────────────────────────────────────────
# MODEL CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
MODEL_ID=tegana/qwen2.5-arabic-finance-news-parser

# ─────────────────────────────────────────────────────────────────────────────
# PART 3 (GROQ LLM DECISION ENGINE)
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_key_here
GROQ_MODEL="llama-3.3-70b-versatile"

# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_CACHE=True
CACHE_TTL=86400